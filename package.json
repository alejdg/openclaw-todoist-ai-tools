{
  "name": "@alejdg/todoist-ai-tools",
  "version": "2.0.0",
  "description": "OpenClaw plugin that exposes Todoist MCP tools to agents via @doist/todoist-mcp",
  "license": "MIT",
  "author": "alejdg",
  "repository": {
    "type": "git",
    "url": "https://github.com/alejdg/todoist-ai-tools"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@doist/todoist-mcp": "^10.4.0",
    "@doist/todoist-sdk": "^10.4.1",
    "zod": "^4.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
